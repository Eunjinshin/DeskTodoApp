{
  "name": "weget-todo",
  "version": "1.0.0",
  "description": "WeGet TODO - Secure Electron Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "pack": "electron-builder build --win"
  },
  "dependencies": {
    "@journeyapps/sqlcipher": "^5.3.1",
    "sqlite3": "^5.1.7",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9"
  },
  "build": {
    "appId": "com.weget.todo",
    "productName": "WeGet TODO",
    "directories": {
      "output": "dist_build"
    },
    "files": [
      "**/*",
      "../03.frontend/dist/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
